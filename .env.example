# Copy to .env and add LiveKit Cloud credentials from https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Broadcast Bridge (Milestone 2). Leave BRIDGE_ENABLED unset for hermetic tests.
# BRIDGE_ENABLED=1
# BRIDGE_CONTROL_URL=http://127.0.0.1:8787
# BRIDGE_WHIP_URL=http://127.0.0.1:8788
# BRIDGE_CALLBACK_HMAC_SECRET=change-me-in-production
# Start the bridge before broadcasting (separate terminal):
#   podman run --rm -p 8787:8787 -p 8788:8788 \
#     -e BRIDGE_CALLBACK_HMAC_SECRET=$BRIDGE_CALLBACK_HMAC_SECRET \
#     -e BRIDGE_LISTEN_HOST=0.0.0.0 \
#     localhost/inilive-broadcast-bridge:bridge-003

# Product database (Milestone 3). Start with: podman compose up -d postgres
DATABASE_URL=postgres://inilive:inilive_dev_password@127.0.0.1:5432/inilive_studio
APP_ORIGIN=http://127.0.0.1:5173

# YouTube Data API managed broadcasts (Milestone 4).
# Create a Google OAuth Web Client and add $APP_ORIGIN/youtube/callback as an authorized redirect URI.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
YOUTUBE_REFRESH_TOKEN_ENCRYPTION_KEY=

# When the bridge runs in Podman on macOS, health callbacks must reach the host app:
# BRIDGE_CALLBACK_ORIGIN=http://host.containers.internal:4173
# Vite preview must allow that host (see vite.config.ts preview.allowedHosts).
